def combinari(x, k):
    if k == 0:
        return [()]
    if len(x) < k:
        return []
    rezultat = []
    for i in range(len(x)):
        elem = x[i]
        rest = x[i + 1:]
        for c in combinari(rest, k - 1):
            rezultat.append((elem,) + c)
    return rezultat

print(combinari([1, 2, 3, 4], 3))
# [(1, 2, 3), (1, 2, 4), (1, 3, 4), (2, 3, 4)]
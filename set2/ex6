def apar_exact_x_ori(*liste, x):
    toate = []
    for lst in liste:
        toate += lst

    rezultat = []
    for elem in toate:
        if toate.count(elem) == x and elem not in rezultat:
            rezultat.append(elem)
    return rezultat

print(apar_exact_x_ori([1, 2, 3], [2, 3, 4], [4, 5, 6], [7, 1, "test"], x=2))
# [1, 2, 3, 4]